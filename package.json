{
  "name": "modurge",
  "author": "Shade",
  "version": "1.2.1",
  "bin": {
    "modurge": "bin/modurge.cjs"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "start": "node bin/modurge.cjs",
    "_compile": "tsc",
    "_compile.watch": "tsc --watch",
    "_copyfiles": "copyfiles --up 1 \"./src/**/*.!(mts|ts)\" dist",
    "pretest": "npm-run-all -c _compile _copyfiles",
    "build": "npm run pretest"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "copyfiles": "^2.4.1",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PickleGherkin/MoDurge.git"
  },
  "bugs": {
    "url": "https://github.com/PickleGherkin/MoDurge/issues"
  },
  "homepage": "https://github.com/PickleGherkin/MoDurge#readme",
  "license": "MIT"
}
